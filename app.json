{
  "expo": {
    "name": "FR Editor",
    "slug": "fr-editor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "freditor",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.leonardonm7.freditor"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "VIBRATE"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.leonardonm7.freditor",
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "react-native-edge-to-edge",
        {
          "android": {
            "parentTheme": "Default",
            "enforceNavigationBarContrast": false
          }
        }
      ],
      [
        "react-native-notify-kit",
        {
          "android": {
            "foregroundService": {
              "types": [
                "mediaPlayback"
              ]
            }
          }
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0fc3878d-71dd-4a70-b2ec-3128afbf8da5"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/0fc3878d-71dd-4a70-b2ec-3128afbf8da5",
      "assetPatternsToBeBundled": [
        "assets/images/**/*",
        "assets/fonts/**/*",
        "assets/exercises/data/**/*",
        "assets/exercises/images/**/*",
        "assets/exercises/videos/**/*",
        "assets/sounds/**/*"
      ]
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
